# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# Master kill switch for Onecta automation (dry-start, dry-stop, check-humidity). GET /health and GET /tasks/device-status still run.
# Set to 0, false, no, off, or disabled to skip those tasks (no public toggle — change via Cloud Run env / Secret Manager).
# AUTOMATION_ENABLED=true

# ── Daikin Onecta OAuth credentials ──────────────────────────────────────────
# Obtain from https://developer.cloud.daikineurope.com/
DAIKIN_CLIENT_ID=your-client-id-here
DAIKIN_CLIENT_SECRET=your-client-secret-here

# Must match the redirect URI registered in the developer portal exactly
# (e.g. Cloud Run oauth stub: https://<service>.a.run.app/oauth/callback).
DAIKIN_REDIRECT_URI=https://your-oauth-stub-host/oauth/callback

# Optional override for the authorize endpoint used by the onboarding helper.
# Leave blank unless Daikin changes the documented endpoint.
DAIKIN_AUTHORIZE_URL=

# Optional bootstrap value only.
# After oauth-exchange, the app stores the live rotating refresh token in the token store below.
# NOT the browser ?code=... parameter (that is a one-time authorization code only).
DAIKIN_REFRESH_TOKEN=your-refresh-token-here

# Rotating refresh-token storage.
# In development the default backend is local-file; in production it defaults to firestore.
# Leave DAIKIN_TOKEN_FILE_PATH empty to use the default local path:
# Windows: %APPDATA%\daikin-humidity-control\refresh-token.json
DAIKIN_TOKEN_STORE=local-file
DAIKIN_TOKEN_FILE_PATH=
DAIKIN_FIRESTORE_COLLECTION=oauth_tokens
DAIKIN_FIRESTORE_DOCUMENT=daikin_onecta

# Firestore collection for full per-device snapshots before DRY (restore on dry-stop).
# DAIKIN_RESTORE_COLLECTION=device_restore_state

# API endpoints (defaults shown — only override if Daikin changes them).
DAIKIN_BASE_URL=https://api.onecta.daikineurope.com
DAIKIN_AUTH_URL=https://idp.onecta.daikineurope.com/v1/oidc/token

# Max concurrent Onecta gateway HTTP calls per process (1–3): GET + PATCH share this cap (default 1).
# DAIKIN_WRITE_CONCURRENCY=1

# Min ms between gated Onecta HTTP completions (sleep while holding the gate; reduces 429 on dry-stop restore). 0 = off.
# DAIKIN_HTTP_PACE_MS=75

# Device UUIDs are not configured here: at runtime the service calls Onecta
# GET /v1/gateway-devices and controls every gateway device returned (see README).

# ── Behaviour ─────────────────────────────────────────────────────────────────
# How long to run DRY mode before the timer-based stop (Option A scheduler).
DRY_DURATION_MINUTES=120

# Frost-protection setpoint applied when reverting to HEAT mode (°C).
HEAT_TARGET_TEMP_C=16

# Hysteresis thresholds (% relative humidity). Only used in humidity strategy.
HUMIDITY_HIGH_THRESHOLD=70
HUMIDITY_LOW_THRESHOLD=60

# Operating mode: "timer" (Scheduler calls dry-start/dry-stop directly)
#             or "humidity" (Scheduler polls check-humidity, FSM decides).
MODE_STRATEGY=timer

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info

# Optional: notify when dry-start / dry-stop runs (Gmail API — needs all five).
# NOTIFY_EMAIL=you@example.com
# GMAIL_SENDER=your-send-as@yourdomain.com
# GMAIL_OAUTH_CLIENT_ID=...
# GMAIL_OAUTH_CLIENT_SECRET=...
# GMAIL_REFRESH_TOKEN=...
# Optional: JSON POST (Zapier/Make/custom). Omit if unused.
# NOTIFY_WEBHOOK_URL=https://hooks.example.com/your-endpoint

# ── Security ──────────────────────────────────────────────────────────────────
# Must match the Cloud Run service URL exactly (used to verify OIDC audience).
# Set to any non-empty string in development — auth is skipped when NODE_ENV=development.
EXPECTED_AUDIENCE=https://daikin-humidity-control-<hash>-<region>.a.run.app
